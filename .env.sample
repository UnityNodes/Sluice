# Copy to .env (gitignored) and fill in real values.

# === CSPR.cloud (sign up at https://cspr.cloud) ===
SLUICE_CSPR_CLOUD_TOKEN=

# === Casper testnet endpoints ===
SLUICE_NODE_RPC_URL=https://node.testnet.cspr.cloud/rpc
SLUICE_STREAMING_WS_URL=wss://streaming.testnet.cspr.cloud/transfers
SLUICE_CHAIN_NAME=casper-test

# === Deployment / runtime ===
# Populated by scripts/deploy-contract.sh once the contract lands.
SLUICE_CONTRACT_HASH=

# Default key paths (created by `casper-client keygen keys/{subscriber,matcher}`).
SLUICE_KEY=./keys/subscriber/secret_key.pem
SLUICE_MATCHER_KEY_PATH=./keys/matcher/secret_key.pem

# === Odra Livenet (used by `scripts/deploy-contract.sh`) ===
ODRA_CASPER_LIVENET_SECRET_KEY_PATH=./keys/matcher/secret_key.pem
ODRA_CASPER_LIVENET_NODE_ADDRESS=https://node.testnet.cspr.cloud
ODRA_CASPER_LIVENET_EVENTS_URL=https://node.testnet.cspr.cloud/events
ODRA_CASPER_LIVENET_CHAIN_NAME=casper-test
CSPR_CLOUD_AUTH_TOKEN=

# === Matcher tuning ===
SLUICE_POLL_SUBS_MS=30000

# === Webhook signing (optional but recommended) ===
# When set, every webhook POST gets X-Sluice-Signature: sha256=<hex>.
# Use a random 32+ byte hex string. See docs/HMAC_VERIFY.md for receiver code.
SLUICE_WEBHOOK_SECRET=

# === Contract-event matching (the SLUICE_WATCH_CONTRACTS feature) ===
# Comma-separated contract package hashes whose CES events the matcher should
# watch in addition to transfers. This is the switch behind contract-event
# predicates (event_type=contract, name=Swap, data.*).
SLUICE_WATCH_CONTRACTS=

# === x402 metered billing ===
# Comma-separated subscription ids billed per-delivery via x402 instead of the
# prepaid escrow. Matches for these subs are queued, not pushed, and an agent
# pulls one by paying. See docs/X402_INTEGRATION.md.
SLUICE_X402_SUBS=

# === HTTP API ===
SLUICE_API_PORT=7799
# Base URL the CLI and MCP server call. Point this at your own matcher when
# self-hosting, otherwise they read the public production instance.
SLUICE_API_URL=http://127.0.0.1:7799
# Writes per client IP per minute.
SLUICE_API_RATE_LIMIT=60
# Where the matcher writes the JSON snapshot Caddy serves as /api/snapshot.json.
SLUICE_SNAPSHOT_PATH=

# === Escrow accounting ===
# Motes deducted per delivery, must match the value the registry was deployed
# with (1 CSPR by default).
SLUICE_PER_DELIVERY_MOTES=1000000000
# Payment attached to each record_delivery transaction.
SLUICE_PAYMENT_MOTES=
# Cap on concurrent casper-client record_delivery subprocesses.
SLUICE_MAX_RECORD_DELIVERY_CONCURRENCY=4
# Cap on concurrent casper-client subprocesses forked by the tx-build HTTP API.
SLUICE_MAX_TX_SUBPROCESS=4
# Separate RPC endpoint for writes, if you send transactions somewhere other
# than the node you read from.
SLUICE_NODE_RPC_URL_WRITE=

# === Demo / local development ===
# Seed the matcher with subscriptions from a JSON file instead of the chain.
SLUICE_INJECT_SUBS_FILE=
# Same thing inline, as a JSON array. SLUICE_INJECT_SUBS_FILE wins if both are set.
SLUICE_INJECT_SUBS=
# Subscription ids to mark as demo traffic in the public feed.
SLUICE_DEMO_SUBS=
# Upper bound on subscriptions held in memory.
SLUICE_MAX_TRACKED_SUBS=
# Path to the casper-client binary used for record_delivery.
CASPER_CLIENT_BIN=
# Path to the `sluice` CLI, used by the MCP server to run signing commands.
SLUICE_CLI_BIN=
# Public URL the hosted MCP server advertises for itself.
SLUICE_MCP_PUBLIC_URL=
# CSPR charged per delivery in the dashboard's balance-runout projection.
# Cosmetic only; the authoritative figure is SLUICE_PER_DELIVERY_MOTES.
SLUICE_DELIVERY_UNIT_COST=
# Recorded WS payload replayed by the offline validation harness.
SLUICE_VALIDATION_SAMPLE_PATH=

# === docker-compose self-host (only used by docker-compose.yml) ===
# Host port for Caddy → defaults to 8080 if unset.
SLUICE_HTTP_PORT=8080
