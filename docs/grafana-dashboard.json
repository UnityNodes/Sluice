{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus instance scraping the Sluice matcher at /api/metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "iteration": 0,
  "links": [
    { "title": "Sluice landing", "url": "https://sluice.unitynodes.com", "type": "link", "icon": "external link", "targetBlank": true },
    { "title": "Sluice status page", "url": "https://sluice.unitynodes.com/status", "type": "link", "icon": "external link", "targetBlank": true }
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active subscriptions",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "sluice_subscriptions{state=\"active\"}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 5 } ] }, "unit": "short" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "graphMode": "none", "colorMode": "background" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Deliveries / min (5m rate)",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "rate(sluice_deliveries_total[5m]) * 60", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }, "unit": "short", "decimals": 1 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "graphMode": "area", "colorMode": "value" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Webhook success rate (5m)",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{
        "refId": "A",
        "expr": "100 * sum(rate(sluice_webhook_results_total{result=\"ok\"}[5m])) / (sum(rate(sluice_webhook_results_total[5m])) > 0)",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
      }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 95 }, { "color": "green", "value": 99 } ] }, "unit": "percent", "decimals": 1, "min": 0, "max": 100 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "graphMode": "none", "colorMode": "background" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Webhook p95 latency",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "histogram_quantile(0.95, sum(rate(sluice_webhook_latency_ms_bucket[5m])) by (le))", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 } ] }, "unit": "ms", "decimals": 0 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "graphMode": "area", "colorMode": "background" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "WS · transfers",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "sluice_ws_connected{stream=\"transfers\"}", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "graphMode": "none", "colorMode": "background" }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "refId": "A", "expr": "sluice_uptime_seconds", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] }, "unit": "s" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "graphMode": "none", "colorMode": "value" }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Webhook latency · p50 / p95 / p99",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum(rate(sluice_webhook_latency_ms_bucket[5m])) by (le))", "legendFormat": "p50", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum(rate(sluice_webhook_latency_ms_bucket[5m])) by (le))", "legendFormat": "p95", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum(rate(sluice_webhook_latency_ms_bucket[5m])) by (le))", "legendFormat": "p99", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "pointSize": 4 }, "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Deliveries · success vs fail (rate/min)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "rate(sluice_webhook_results_total{result=\"ok\"}[5m]) * 60", "legendFormat": "ok", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "refId": "B", "expr": "rate(sluice_webhook_results_total{result=\"fail\"}[5m]) * 60", "legendFormat": "fail", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "stacking": { "mode": "normal" } }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ok" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] },
          { "matcher": { "id": "byName", "options": "fail" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      },
      "options": { "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Subscriptions over time (by state)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "sluice_subscriptions{state=\"active\"}", "legendFormat": "active", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "refId": "B", "expr": "sluice_subscriptions{state=\"inactive\"}", "legendFormat": "inactive", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5 }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "On-chain record_delivery results",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "rate(sluice_record_delivery_results_total{result=\"ok\"}[5m]) * 60", "legendFormat": "ok", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } },
        { "refId": "B", "expr": "rate(sluice_record_delivery_results_total{result=\"fail\"}[5m]) * 60", "legendFormat": "fail", "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" } }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8 }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ok" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } } ] },
          { "matcher": { "id": "byName", "options": "fail" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": { "legend": { "showLegend": true, "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["sluice", "casper", "webhooks"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"] },
  "timezone": "browser",
  "title": "Sluice, matcher overview",
  "uid": "sluice-matcher-overview",
  "version": 1,
  "weekStart": ""
}
