# Real x402 integration config. Copy to .env and fill in your own values.
# Never commit a real FACILITATOR_API_KEY or a private key.

# --- Receiver (x402-receiver.mjs) ---
# Live hosted Casper x402 facilitator (mainnet + testnet on one host).
FACILITATOR_URL=https://x402-facilitator.cspr.cloud
# Your CSPR.cloud access token (a plain UUID). Get one at https://console.cspr.build .
FACILITATOR_API_KEY=your-cspr-cloud-token
# CAIP-2 network id: casper:casper-test (testnet) or casper:casper (mainnet).
CAIP2_CHAIN_ID=casper:casper-test
# 66-char payee key (format 00<64-hex account hash>). This account receives the payment.
PAYEE_ADDRESS=00<your-account-hash>
# 64-hex package hash of a deployed x402-capable CEP-18 token (transfer_with_authorization).
# The reference below is the "Sluice X402 Token (SLX)" we deployed on testnet.
ASSET_PACKAGE=220ed4c8e5368063ec167d738d1b96d5760833366af4a1194264312a766db88b
ASSET_NAME=Sluice X402 Token
ASSET_SYMBOL=SLX
# Price per delivery in the token's base units (9 decimals). 100000000 = 0.1 SLX.
PRICE_AMOUNT=100000000
PORT=4021

# --- Payer (x402-payer.mjs) ---
# PEM key of the paying agent. It must hold a balance of ASSET_PACKAGE above.
CLIENT_PRIVATE_KEY_PATH=./keys/subscriber/secret_key.pem
CLIENT_KEY_ALGO=ed25519
SERVER_URL=http://localhost:4021
